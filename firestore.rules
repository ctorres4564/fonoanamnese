rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /professionalProfiles/{userId} {
      // Must be authenticated to access anything
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Can only create their own profile, and the document ID must match their UID
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.userId == request.auth.uid;

      // Can update their own profile, but cannot change the userId
      allow update: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.userId == request.auth.uid;
    }

    match /patients/{patientId} {
      // Professional can read their own patients
      allow read: if request.auth != null && resource.data.professionalId == request.auth.uid;

      // Professional can create patients, tying to their ID
      allow create: if request.auth != null && request.resource.data.professionalId == request.auth.uid;

      // Professional can update their own patients, preventing transfer of ownership
      allow update: if request.auth != null 
                    && resource.data.professionalId == request.auth.uid 
                    && request.resource.data.professionalId == request.auth.uid;
    }

    match /guardians/{guardianId} {
      // Professional can read guardians for their own patients
      allow read: if request.auth != null && resource.data.professionalId == request.auth.uid;

      // Professional can create guardians for their patients
      allow create: if request.auth != null && request.resource.data.professionalId == request.auth.uid;

      // Professional can update guardians for their patients, preventing transfer of ownership
      allow update: if request.auth != null 
                    && resource.data.professionalId == request.auth.uid 
                    && request.resource.data.professionalId == request.auth.uid;
    }
    match /anamneses/{anamnesisId} {
      allow read: if request.auth != null && resource.data.professionalId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.professionalId == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.professionalId == request.auth.uid 
                    && request.resource.data.professionalId == request.auth.uid
                    && request.resource.data.patientId == resource.data.patientId;
    }

    match /anamnesisVersions/{versionId} {
      allow read: if request.auth != null && resource.data.professionalId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.professionalId == request.auth.uid;
      allow update: if false; // Snapshots are immutable
    }
  }
}
